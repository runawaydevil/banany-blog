generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  passwordHash        String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
}

model SiteSettings {
  id     String @id @default("singleton")

  siteTitle      String  @default("Banany Blog")
  browserTitle   String?
  dashboardTitle String?
  publicUrl      String  @default("http://localhost:3000")
  locale         String  @default("en")
  introSnippet   String? @db.Text

  themePreset    String  @default("paper")
  themeOverrides Json?
  customCss      String? @db.Text

  faviconMediaId   String?
  logoMediaId      String?

  newsletterEnabledHome Boolean @default(false)
  newsletterEnabledPost Boolean @default(false)
  newsletterAutoPostPublishEnabled Boolean @default(false)

  setupComplete Boolean @default(false)
  homePageSlug  String?

  seoDescription String?

  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

enum PostType {
  NOTE
  POST
  PHOTO
  LINK
  QUOTE
  REPLY
}

enum PostContentFormat {
  RICH_TEXT
  MARKDOWN
}

enum ContentLocale {
  en
  pt
}

model PostGroup {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  posts     PostTranslation[]
  legacyPosts Post[]         @relation("LegacyPostGroup")
}

model PostTranslation {
  id            String            @id @default(cuid())
  groupId       String
  group         PostGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  locale        ContentLocale

  type          PostType          @default(POST)
  title         String?
  slug          String            @unique
  contentFormat PostContentFormat @default(RICH_TEXT)
  content       String            @db.Text
  published     Boolean           @default(false)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  notifySubscribersOnPublish Boolean @default(true)
  pinned        Boolean           @default(false)
  tags          String[]          @default([])
  linkUrl       String?

  previewToken  String?           @unique
  previewEnabledAt DateTime?
  previewRevokedAt DateTime?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([groupId, locale])
}

model Post {
  id          String    @id @default(cuid())
  groupId     String?   @unique
  group       PostGroup? @relation("LegacyPostGroup", fields: [groupId], references: [id], onDelete: SetNull)
  type        PostType  @default(POST)
  title       String?
  slug        String    @unique
  contentFormat PostContentFormat @default(RICH_TEXT)
  content     String    @db.Text
  published   Boolean   @default(false)
  scheduledAt DateTime?
  publishedAt DateTime?
  notifySubscribersOnPublish Boolean @default(true)
  pinned      Boolean   @default(false)
  tags        String[]  @default([])
  linkUrl     String?
  previewToken String?  @unique
  previewEnabledAt DateTime?
  previewRevokedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  newsletterCampaigns NewsletterCampaign[]
}

model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String    @db.Text
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NavItem {
  id    String @id @default(cuid())
  label String
  href  String
  order Int    @default(0)
}

model Subscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  unsubscribeToken String   @unique
  unsubscribedAt   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum NewsletterCampaignKind {
  MANUAL
  POST_PUBLISH
}

enum NewsletterCampaignStatus {
  SENT
  PARTIAL
  FAILED
}

enum JobType {
  NEWSLETTER_POST_PUBLISH
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model Job {
  id         String    @id @default(cuid())
  type       JobType
  status     JobStatus @default(PENDING)

  postId     String?
  payload    Json?

  runAt      DateTime  @default(now())
  attempts   Int       @default(0)
  maxAttempts Int      @default(8)

  lockedAt   DateTime?
  lockedBy   String?
  lastError  String?

  result     Json?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([type, postId])
  @@index([status, runAt])
}

model NewsletterCampaign {
  id             String                   @id @default(cuid())
  kind           NewsletterCampaignKind   @default(MANUAL)
  status         NewsletterCampaignStatus @default(SENT)
  postId         String?                  @unique
  post           Post?                    @relation(fields: [postId], references: [id], onDelete: SetNull)
  subject        String
  previewText    String?                  @db.VarChar(300)
  bodyHtml       String                   @db.Text
  bodyText       String                   @db.Text
  recipientCount Int
  failureCount   Int                      @default(0)
  sentAt         DateTime                 @default(now())
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  /// SHA-256 hex of the raw token sent by email (raw token is never stored)
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
