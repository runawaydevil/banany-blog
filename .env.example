# Copy to `.env` for local `npm run dev` / `docker compose` (development file).

# --- Required (production; recommended locally too) ---
DATABASE_URL="postgresql://banany:banany@localhost:35432/banany"
AUTH_SECRET="generate-a-long-random-string"

# Canonical public origin (scheme + host, no trailing slash). Used for sitemap,
# feeds, password-reset links, and media proxy URLs when S3_PUBLIC_URL is unset.
# Fallback chain: APP_URL → SITE_URL → NEXTAUTH_URL → NEXT_PUBLIC_APP_URL
APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- S3-compatible storage (MinIO locally) ---
S3_ENDPOINT="http://localhost:39000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio12345"
S3_BUCKET="banany"
# S3_PUBLIC_URL=""

# --- Optional: Mailgun (password reset); dashboard no longer stores these ---
# MAILGUN_API_KEY=""
# MAILGUN_DOMAIN=""
# MAILGUN_FROM="Banany <noreply@mg.example.com>"
# MAILGUN_REPLY_TO=""
# MAILGUN_REGION="us"

# --- Optional dev / ops ---
# Set when TLS terminates at reverse proxy (HSTS + secure cookies)
# BANANY_BEHIND_HTTPS_PROXY=1
# ALLOW_LOCALHOST_PUBLIC_URL=1
# BANANY_REQUIRE_MAILGUN=1
# SKIP_DB_PUSH=1

# Background jobs runner (POST /api/jobs/run)
# JOBS_RUNNER_TOKEN="generate-a-long-random-string"

# --- Docker Compose host port overrides (development compose only) ---
# Defaults match docker-compose.yml: app 3000, Postgres 35432, MinIO 39000/39001
# BANANY_APP_PORT_HOST=3000
# BANANY_DB_PORT_HOST=35432
# BANANY_MINIO_API_PORT_HOST=39000
# BANANY_MINIO_CONSOLE_PORT_HOST=39001
