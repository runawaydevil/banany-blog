# Copy to `.env` (or keep a separate prod file) and use with:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d --build
# Terminate TLS and route traffic on your public domain with your own reverse proxy
# to the app port (default host mapping 38127 → container 3000).

# --- Core ---
NODE_ENV=production
AUTH_SECRET=replace-with-long-random-secret
POSTGRES_PASSWORD=replace-with-strong-db-password
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
S3_BUCKET=banany

# Public URL users see in the browser (https recommended).
APP_URL=https://blog.example.com
NEXTAUTH_URL=https://blog.example.com

# Enable HSTS response header and secure cookie defaults aligned with HTTPS
BANANY_BEHIND_HTTPS_PROXY=1
# Optional; keep in sync with APP_URL if any client-side absolute URL is needed
NEXT_PUBLIC_APP_URL=https://blog.example.com

# App published on host at this port (compose maps it to container 3000)
BANANY_APP_PORT_HOST=38127

# --- Mailgun (optional; required for password reset email) ---
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_FROM=Banany <noreply@mg.example.com>
# MAILGUN_REPLY_TO=
# MAILGUN_REGION=us

# Fail container start if Mailgun is not configured
# BANANY_REQUIRE_MAILGUN=1

# Only for controlled local prod testing (not on the public internet)
# ALLOW_LOCALHOST_PUBLIC_URL=1
